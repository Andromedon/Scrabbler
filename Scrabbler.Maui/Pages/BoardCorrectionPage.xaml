<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Scrabbler.Maui.Pages.BoardCorrectionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Correct Board">
    <Grid Padding="16" RowDefinitions="Auto,*,Auto,Auto,Auto" RowSpacing="12">
        <Label Grid.Row="0" Text="{Binding DetectedCellsText}" LineBreakMode="WordWrap" />
        <ScrollView Grid.Row="1" Orientation="Both">
            <VerticalStackLayout
                Padding="10"
                BackgroundColor="{AppThemeBinding Light=#F7F3EA, Dark=#1F1F1F}"
                BindableLayout.ItemsSource="{Binding BoardLines}"
                Spacing="0"
                VerticalOptions="Fill">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Label
                            Text="{Binding .}"
                            FontFamily="Menlo"
                            FontSize="16"
                            LineBreakMode="NoWrap"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </ScrollView>
        <Entry
            Grid.Row="2"
            Placeholder="A1=Ł, H8=?, J10=."
            Text="{Binding Corrections}" />
        <HorizontalStackLayout Grid.Row="3" Spacing="12">
            <Button Text="Apply" Command="{Binding ApplyCommand}" />
            <Button Text="Continue" Command="{Binding ContinueCommand}" />
        </HorizontalStackLayout>
        <ScrollView Grid.Row="4" MaximumHeightRequest="96">
            <Label Text="{Binding Message}" TextColor="DarkRed" LineBreakMode="WordWrap" />
        </ScrollView>
    </Grid>
</ContentPage>

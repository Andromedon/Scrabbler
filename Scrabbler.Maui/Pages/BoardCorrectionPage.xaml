<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Scrabbler.Maui.Pages.BoardCorrectionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Correct Board">
    <Grid Padding="16" RowDefinitions="Auto,*,Auto,Auto,Auto,Auto" RowSpacing="12">
        <VerticalStackLayout Grid.Row="0" Spacing="6">
            <Label Text="{Binding ReviewCellsText}" LineBreakMode="WordWrap" />
            <Button
                Text="{Binding DetectedToggleText}"
                Command="{Binding ToggleDetectedCellsCommand}"
                FontSize="13"
                MinimumHeightRequest="34"
                Padding="8,4"
                HorizontalOptions="Start" />
            <ScrollView IsVisible="{Binding IsDetectedCellsExpanded}" MaximumHeightRequest="92">
                <Label
                    Text="{Binding DetectedCellsText}"
                    FontSize="11"
                    LineBreakMode="WordWrap" />
            </ScrollView>
        </VerticalStackLayout>
        <Border
            x:Name="BoardHost"
            Grid.Row="1"
            Padding="0"
            BackgroundColor="{AppThemeBinding Light=#F7F3EA, Dark=#1F1F1F}"
            HorizontalOptions="Center"
            Stroke="{AppThemeBinding Light=#D8D0C1, Dark=#333333}"
            StrokeThickness="1"
            VerticalOptions="Center">
            <Grid
                x:Name="BoardGrid"
                BindableLayout.ItemsSource="{Binding BoardCells}"
                ColumnSpacing="1"
                RowSpacing="1">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Button
                            Grid.Row="{Binding GridRow}"
                            Grid.Column="{Binding GridColumn}"
                            BackgroundColor="{Binding BackgroundColor}"
                            BorderColor="{AppThemeBinding Light=#D9D4CC, Dark=#3A3A3A}"
                            BorderWidth="0.5"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectBoardCellCommand}"
                            CommandParameter="{Binding CorrectionPrefix}"
                            CornerRadius="2"
                            FontAttributes="Bold"
                            FontSize="15"
                            IsEnabled="{Binding IsEnabled}"
                            MinimumHeightRequest="0"
                            MinimumWidthRequest="0"
                            Padding="0"
                            Text="{Binding Letter}"
                            TextColor="{Binding TextColor}" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </Grid>
        </Border>
        <ScrollView Grid.Row="2" Orientation="Horizontal">
            <HorizontalStackLayout
                BindableLayout.ItemsSource="{Binding QuickCorrections}"
                Spacing="8">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Button
                            Text="{Binding Label}"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectQuickCorrectionCommand}"
                            CommandParameter="{Binding CorrectionText}"
                            FontSize="13"
                            MinimumHeightRequest="34"
                            Padding="10,4" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>
        <Entry
            x:Name="CorrectionsEntry"
            Grid.Row="3"
            CharacterSpacing="0"
            Keyboard="Text"
            Placeholder="A1=Ł, H8=?, J10=."
            Text="{Binding Corrections}"
            TextTransform="Uppercase" />
        <HorizontalStackLayout Grid.Row="4" Spacing="12">
            <Button Text="Apply" Command="{Binding ApplyCommand}" />
            <Button Text="Continue" Command="{Binding ContinueCommand}" />
        </HorizontalStackLayout>
        <ScrollView Grid.Row="5" MaximumHeightRequest="96">
            <Label Text="{Binding Message}" TextColor="DarkRed" LineBreakMode="WordWrap" />
        </ScrollView>
    </Grid>
</ContentPage>

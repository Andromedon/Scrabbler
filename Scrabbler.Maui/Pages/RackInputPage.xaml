<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Scrabbler.Maui.Pages.RackInputPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Rack">
    <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,*,Auto">
        <VerticalStackLayout Grid.Row="1" Spacing="14">
            <Entry
                CharacterSpacing="0"
                Keyboard="Text"
                Placeholder="Rack letters (? for blank)"
                Text="{Binding RackText}"
                TextTransform="Uppercase" />
            <Button Text="Solve" Command="{Binding SolveCommand}" />
            <ActivityIndicator IsRunning="{Binding IsSolving}" IsVisible="{Binding IsSolving}" />
            <Label Text="{Binding Message}" TextColor="DarkRed" LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>

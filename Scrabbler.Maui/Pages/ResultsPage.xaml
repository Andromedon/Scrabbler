<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Scrabbler.Maui.Pages.ResultsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Results">
    <Grid Padding="16" RowDefinitions="*,Auto" RowSpacing="12">
        <ScrollView Grid.Row="0">
            <Label Text="{Binding ResultsText}" FontFamily="Menlo" FontSize="14" LineBreakMode="WordWrap" />
        </ScrollView>
        <Button Grid.Row="1" Text="Finish" Command="{Binding FinishCommand}" />
    </Grid>
</ContentPage>
